{
  "name": "lan-markdown-notes",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/desktop/main.js",
  "scripts": {
    "dev": "concurrently -k -n server,client -c cyan,magenta \"npm:dev:server\" \"npm:dev:client\"",
    "dev:server": "cross-env NODE_ENV=development PORT=3211 tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "vite build && tsup src/server/index.ts --format esm --platform node --target node20 --out-dir dist/server --clean",
    "start": "node dist/server/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "android:sync": "npm run build && cap sync android",
    "android:open": "cap open android",
    "android:debug": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:test": "powershell -ExecutionPolicy Bypass -File scripts/test-android.ps1",
    "android:apk": "powershell -ExecutionPolicy Bypass -File scripts/build-android-apk.ps1",
    "desktop:build": "npm run build && tsup src/desktop/main.ts --format esm --platform node --target node20 --out-dir dist/desktop --clean --external electron",
    "desktop:dev": "npm run desktop:build && electron .",
    "desktop:dist": "npm run desktop:build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.personal.markdownnotes.desktop",
    "productName": "个人笔记",
    "directories": {
      "output": "dist-desktop"
    },
    "files": [
      "dist/client/**/*",
      "dist/desktop/**/*",
      "build/icon.png",
      "package.json"
    ],
    "extraMetadata": {
      "main": "dist/desktop/main.js"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/keyboard": "^8.0.5",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@codemirror/language-data": "^6.5.2",
    "@dnd-kit/core": "latest",
    "@dnd-kit/sortable": "latest",
    "@dnd-kit/utilities": "latest",
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "latest",
    "@fastify/static": "latest",
    "@milkdown/crepe": "latest",
    "@radix-ui/react-alert-dialog": "latest",
    "@radix-ui/react-dropdown-menu": "latest",
    "@radix-ui/react-tooltip": "latest",
    "archiver": "latest",
    "chokidar": "latest",
    "fastify": "latest",
    "gray-matter": "latest",
    "lucide-react": "latest",
    "mdast-util-to-string": "latest",
    "minisearch": "latest",
    "react": "latest",
    "react-dom": "latest",
    "remark-parse": "latest",
    "unified": "latest"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@eslint/js": "latest",
    "@playwright/test": "latest",
    "@testing-library/jest-dom": "latest",
    "@testing-library/react": "latest",
    "@testing-library/user-event": "latest",
    "@types/archiver": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "concurrently": "latest",
    "cross-env": "latest",
    "electron": "^42.5.1",
    "electron-builder": "^26.15.3",
    "eslint": "latest",
    "eslint-plugin-react-hooks": "latest",
    "eslint-plugin-react-refresh": "latest",
    "globals": "latest",
    "jsdom": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "vite": "latest",
    "vitest": "latest"
  }
}
